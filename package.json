{
  "name": "throughline",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "A Zachtronic-style flow-routing puzzle game with LLM-generated campaigns.",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "throughline-gen": "./bin/throughline-gen"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:cli": "tsc -p cli/tsconfig.json --noEmit && esbuild cli/src/index.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist-cli/throughline-gen.mjs --loader:.md=text --loader:.json=json --external:node:*",
    "preview": "vite preview --port 4173",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "vitest run",
    "pretest:e2e": "npm run build",
    "test:e2e": "playwright test",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "tone": "^15.0.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^25.9.1",
    "@vitest/ui": "^2.1.0",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^9.1.0",
    "fast-check": "^4.8.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.11.0",
    "vite": "^5.4.10",
    "vitest": "^2.1.0"
  }
}
