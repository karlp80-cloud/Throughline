{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Throughline",
  "version": "0.1.0",
  "identifier": "org.throughline.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Throughline",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis", "deb", "appimage", "dmg"],
    "category": "Game",
    "shortDescription": "Zachtronic-style flow-routing puzzles with LLM-generated campaigns.",
    "longDescription": "Throughline is a Zachtronic-style flow-routing puzzle game whose mechanics are fixed but whose themes, narrative, and puzzle layouts are generated by an LLM. Place tiles, route flow between inputs and outputs, and solve hand-crafted or procedurally-generated campaigns.",
    "copyright": "© 2026 Throughline contributors",
    "publisher": "Throughline",
    "licenseFile": "../LICENSE",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["../bin/throughline-gen", "../dist-cli/**/*", "../campaigns/samples/**/*.json"],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
